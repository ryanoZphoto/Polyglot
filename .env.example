BOT_MODE=dry_run

# Public endpoints
PM_GAMMA_HOST=https://gamma-api.polymarket.com
PM_CLOB_HOST=https://clob.polymarket.com
PM_CHAIN_ID=137

# Strategy/risk tuning
BOT_SCAN_LIMIT=200
BOT_MIN_LIQUIDITY=5000
BOT_MIN_EDGE=0.01
BOT_MIN_PROFIT_USD=1.0
BOT_MAX_CAPITAL_PER_TRADE=100
BOT_MAX_BUNDLE_SHARES=100
BOT_MIN_GROUP_SIZE=4
BOT_MAX_GROUP_SIZE=12
BOT_MAX_OPPS_PER_CYCLE=3
BOT_MARKET_COOLDOWN_SECONDS=20
BOT_POLL_INTERVAL_SECONDS=2
BOT_SPORTS_ONLY=true
BOT_INCLUDE_KEYWORDS=
BOT_REQUEST_TIMEOUT_SECONDS=10
BOT_MAX_WORKERS=20

# Live mode credentials (required only when BOT_MODE=live)
# Signature type: 0=EOA, 1=POLY_PROXY, 2=GNOSIS_SAFE (Polymarket default often 2)
PM_SIGNATURE_TYPE=2
PM_PRIVATE_KEY=
PM_FUNDER=
PM_API_KEY=
PM_API_SECRET=
PM_API_PASSPHRASE=
