# Event Trader - Improved Version Config

# NEW PARAMETERS (improvements)
MIN_EDGE=0.01                      # Minimum 1% edge to enter (lowered for testing)
MAX_SPREAD_PCT=0.05                # Skip if spread > 5%
MIN_VOLUME_24H=100                 # Minimum daily volume

USE_KELLY_SIZING=true              # Use Kelly Criterion
KELLY_FRACTION=0.25                # Quarter-Kelly (conservative)
TARGET_VOLATILITY=0.15             # Target 15% portfolio vol
MAX_POSITION_PCT=0.10              # Max 10% per position

TRAILING_ACTIVATION_PCT=0.05       # Start trailing at 5% profit
TIME_DECAY_DAYS=1                  # Tighten stops within 1 day
TIME_DECAY_STOP_PCT=0.05           # Max 5% loss near close
VOLATILITY_MULTIPLIER=2.0          # Trailing cushion

# ORIGINAL PARAMETERS (keep these)
MAX_ENTRY_PRICE=0.40
MIN_ENTRY_PRICE=0.02
MIN_BOOK_DEPTH_USD=50
MIN_SPREAD_RATIO=0.30

POSITION_SIZE_USD=5
LONGSHOT_SIZE_USD=2
HIGHPROB_SIZE_USD=8
LONGSHOT_CEILING=0.30
HIGHPROB_FLOOR=0.55

TAKE_PROFIT_PCT=0.50
STOP_LOSS_PCT=0.40
TRAILING_STOP_PCT=0.20
LONGSHOT_TAKE_PROFIT_PCT=1.50
LONGSHOT_STOP_LOSS_PCT=0.50
HIGHPROB_TAKE_PROFIT_PCT=0.30
HIGHPROB_STOP_LOSS_PCT=0.20

MAX_TOTAL_EXPOSURE_USD=100
MAX_DAILY_LOSS_USD=25
MAX_PER_MARKET_USD=20
